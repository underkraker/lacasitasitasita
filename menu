#!/bin/bash
# ==============================================================================
# KRAKER ELITE PANEL (v2.0) - INTERFAZ MINIMALISTA
# ==============================================================================
# Iniciar Entorno Elite
[[ -f /etc/kraker/core.sh ]] && source /etc/kraker/core.sh || source ./kraker_core.sh

clear
k_msg -title "KRAKER ELITE COMMAND CENTER"

# 1. Información del Sistema en una Línea Real-Time
read r_total r_used r_free <<< $(free -h | awk '/Mem:/ {print $2, $3, $4}')
cpu_load=$(top -bn1 | awk '/Cpu/ {print $2 + $4 "%"}')
k_msg "-info" "RAM: ${GREEN}$r_used / $r_total${NC} | CPU: ${GREEN}$cpu_load${NC} | OS: ${CYAN}$(k_get_os)${NC}"
k_msg -bar

# 2. Estado de Servicios Clave
k_status() {
  local s_name=$1
  local d_name=$2
  echo -ne " ${WHITE}$d_name: " && k_service status "$s_name"
}

k_status "sshd" "SSH"
k_status "dropbear" "Dropbear"
k_status "stunnel4" "SSL/TLS"
k_status "squid" "Squid"
k_status "apache2" "Web"
k_msg -bar

# 3. Navegación Principal
menu_option() {
  echo -e " ${BLUE}$1${NC} ${GRAY}→${NC} ${WHITE}$2${NC}"
}

menu_option "01" "Gestiön de Protocolos (Elite Edition)"
menu_option "02" "Administraciön de Usuarios (SSH/SSL)"
menu_option "03" "Ajustes del Sistema y Firewall"
menu_option "04" "Herramientas de Red y Optimizaciön"
menu_option "05" "Monitor de Träfico y Logs"
k_msg -bar

menu_option "00" "${RED}Cerrar Comando Elite${NC}"
k_msg -bar

# 4. Captura de Opciones
echo -ne " ${CYAN}➤ ${WHITE}Seleccione una opciön: ${NC}" && read selection

case "$selection" in
  01) "$K_DIR/protocols.sh" ;;
  02) "$K_DIR/user_manager.sh" ;;
  00) clear && exit 0 ;;
  *) clear && exec "$0" ;;
esac